{
    "name": "axm-api",
    "description": "",
    "version": "0.0.0",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "build": "bun build src/index.ts --target=bun --outdir=dist",
        "start": "bun run dist/index.js",
        "prepare": "lefthook install",
        "check": "bun run lint:fix && bun run check:types && bun run check:dead-code && bun run check:dupes && bun run check:health",
        "check:types": "tsc --noEmit",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "test:coverage": "bun test --coverage",
        "check:dead-code": "bun run fallow dead-code",
        "check:dupes": "bun run fallow dupes",
        "check:health": "bun run fallow health",
        "check:audit": "bun run fallow audit",
        "review": "diffscopeplus review",
        "review:staged": "diffscopeplus staged",
        "review:last-commit": "diffscopeplus last-commit",
        "review:branch": "diffscopeplus branch"
    },
    "dependencies": {
        "@novadi/core": "^0.6.1",
        "@sentry/bun": "^10.57.0",
        "hono": "^4.12.25",
        "pino": "^10.3.1",
        "pino-loki": "^3.0.0",
        "pino-pretty": "^13.1.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@types/bun": "^1.3.14",
        "fallow": "^2.94.0",
        "lefthook": "^2.1.9",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {},
    "engines": {
        "bun": ">=1.3.0"
    }
}
