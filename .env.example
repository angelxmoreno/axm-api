# App
# Display name for the service. Used in logs, Sentry tags, and Loki labels.
APP_NAME=axm-api

# Runtime environment. Used by Sentry, logging filters, error verbosity.
# Expected values: development | production | test
NODE_ENV=development

# HTTP server
# Hostname the server binds to. Defaults to localhost.
HTTP_HOSTNAME=localhost

# Port the server binds to. Must be a number (env var strings are coerced).
# Defaults to 3001.
HTTP_PORT=3001

# Sentry
# DSN for error reporting. Leave empty to disable.
SENTRY_DSN=

# Logger
# Pretty-print to stdout. Set to false in production.
# Truthy: true, 1, yes, on, y, enabled (case-insensitive)
# Falsy:  false, 0, no, off, n, disabled
LOGGER_USE_PRETTY=true

# Log level: silent | fatal | error | warn | info | debug | trace
LOGGER_LEVEL=info

# Optional. Loki push endpoint. Leave empty to disable Loki transport.
LOGGER_LOKI_URL=
