# App
# Display name for the service. Used in logs, Sentry tags, and Loki labels.
APP_NAME=axm-api

# Runtime environment. Used by Sentry, logging filters, error verbosity.
# Expected values: development | production | test
NODE_ENV=development

# HTTP server
# Hostname the server binds to. Defaults to localhost.
HTTP_HOSTNAME=localhost

# Port the server binds to. Must be a number (env var strings are coerced).
# Defaults to 3001.
HTTP_PORT=3001

# Sentry
# DSN for error reporting. Leave empty to disable.
SENTRY_DSN=

# CORS
# CORS_ORIGIN: single origin string, comma-separated list, or '*' for all. Defaults to '*'.
CORS_ORIGIN=*
# CORS_ALLOWED_METHODS: comma-separated HTTP methods. Defaults to GET,POST,PUT,PATCH,DELETE,OPTIONS.
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOWED_HEADERS: comma-separated header names. Defaults to content-type,authorization.
CORS_ALLOWED_HEADERS=content-type,authorization
# CORS_MAX_AGE: max-age value in seconds for preflight cache. Defaults to 86400.
CORS_MAX_AGE=86400
# CORS_CREDENTIALS: whether to allow credentials. Defaults to false.
CORS_CREDENTIALS=false
# CORS_EXPOSE_HEADERS: comma-separated headers exposed to the client. Defaults to empty.
CORS_EXPOSE_HEADERS=

# Rate Limiter
# RATE_LIMITER_WINDOW_MS: time window in milliseconds. Defaults to 900000 (15 minutes).
RATE_LIMITER_WINDOW_MS=900000
# RATE_LIMITER_LIMIT: max requests per window per client. Defaults to 100.
RATE_LIMITER_LIMIT=100

# Secure Headers
# Each key maps to hono/secure-headers. Set to true/false or a literal header value.
# Defaults listed below are the recommended production-safe defaults.
SECURE_HEADERS_CROSS_ORIGIN_EMBEDDER_POLICY=false
SECURE_HEADERS_CROSS_ORIGIN_RESOURCE_POLICY=true
SECURE_HEADERS_CROSS_ORIGIN_OPENER_POLICY=true
SECURE_HEADERS_ORIGIN_AGENT_CLUSTER=true
SECURE_HEADERS_REFERRER_POLICY=true
SECURE_HEADERS_STRICT_TRANSPORT_SECURITY=true
SECURE_HEADERS_X_CONTENT_TYPE_OPTIONS=true
SECURE_HEADERS_X_DNS_PREFETCH_CONTROL=true
SECURE_HEADERS_X_DOWNLOAD_OPTIONS=true
SECURE_HEADERS_X_FRAME_OPTIONS=true
SECURE_HEADERS_X_PERMITTED_CROSS_DOMAIN_POLICIES=true
SECURE_HEADERS_X_XSS_PROTECTION=true
SECURE_HEADERS_REMOVE_POWERED_BY=true

# Logger
# Pretty-print to stdout. Set to false in production.
# Truthy: true, 1, yes, on, y, enabled (case-insensitive)
# Falsy:  false, 0, no, off, n, disabled
LOGGER_USE_PRETTY=true

# Log level: silent | fatal | error | warn | info | debug | trace
LOGGER_LEVEL=info

# Optional. Loki push endpoint. Leave empty to disable Loki transport.
LOGGER_LOKI_URL=
